        Window._Minimized = not Window._Minimized
        if Window._Minimized then
            MinimizeBtn.Text = "+"
            TabListBG.Visible = false
            ContentArea.Visible = false
            Tween(Main, { Size = UDim2.new(0, Window._OriginalSize.X.Offset, 0, 44) }, 0.2)
        else
            MinimizeBtn.Text = "_"
            Tween(Main, { Size = Window._OriginalSize }, 0.2)
            task.wait(0.2)
            TabListBG.Visible = true
            ContentArea.Visible = true
        end
    end)

    table.insert(Window._ThemeRefreshers, function(Theme)
        MinimizeBtn.TextColor3 = Theme.SubText
    end)

    return Window
end

----------------------------------------------------------------
-- SetTheme: ganti tema realtime
----------------------------------------------------------------
function MyHub:SetTheme(themeName)
    local Theme = Themes[themeName]
    if not Theme then return end
    self.Theme = Theme
    self.ThemeName = themeName

    Tween(self.Main, { BackgroundColor3 = Theme.Background }, 0.2)
    Tween(self._TopBar, { BackgroundColor3 = Theme.Secondary }, 0.2)
    if self._TabListBG then Tween(self._TabListBG, { BackgroundColor3 = Theme.Secondary }, 0.2) end
    if self._Divider then Tween(self._Divider, { BackgroundColor3 = Theme.Stroke }, 0.2) end

    -- refresh semua elemen yang terdaftar via tag ElementRefs
    for _, refresh in ipairs(self._ThemeRefreshers or {}) do
        pcall(refresh, Theme)
    end
end
MyHub.__newindex = function(t, k, v) rawset(t, k, v) end

