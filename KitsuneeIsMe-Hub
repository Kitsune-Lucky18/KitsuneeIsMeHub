function KitsuneeIsMe:CreateTab(name, icon)
    local Window = self
    local iconUri = resolveIcon(icon)
    local textInset = iconUri and 34 or 12

    local TabButton = Create("TextButton", {
        Size = UDim2.new(1, 0, 0, 32),
        BackgroundColor3 = Window.Theme.ElementBG,
        Text = "",
        AutoButtonColor = false,
        Parent = Window._TabList,
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
    })

    local TabIcon
    if iconUri then
        TabIcon = Create("ImageLabel", {
            Image = iconUri,
            BackgroundTransparency = 1,
            Size = UDim2.fromOffset(16, 16),
            Position = UDim2.fromOffset(10, 8),
            ImageColor3 = Window.Theme.SubText,
            Parent = TabButton,
        })
    end

    local TabLabel = Create("TextLabel", {
        Text = name,
        Font = Enum.Font.Gotham,
        TextSize = 14,
        TextColor3 = Window.Theme.SubText,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -textInset - 8, 1, 0),
        Position = UDim2.fromOffset(textInset, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = TabButton,
    })

    local TabPage = Create("ScrollingFrame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Window.Theme.Accent,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        Parent = Window._ContentArea,
    }, {
        Create("UIListLayout", { Padding = UDim.new(0, 8) }),
        Create("UIPadding", {
            PaddingLeft = UDim.new(0, 4), PaddingRight = UDim.new(0, 8),
            PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 12),
        }),
    })

    local Tab = BuildElements(Window, TabPage)
    Tab.Button = TabButton
    Tab.Page = TabPage
    Tab.Window = Window
    Tab.Name = name

    local function selectTab()
        for _, t in ipairs(Window.Tabs) do
            t.Page.Visible = false
            Tween(t.Button, { BackgroundColor3 = Window.Theme.ElementBG }, 0.15)
            if t.Label then Tween(t.Label, { TextColor3 = Window.Theme.SubText }, 0.15) end
            if t.Icon then Tween(t.Icon, { ImageColor3 = Window.Theme.SubText }, 0.15) end
        end
        TabPage.Visible = true
        Tween(TabButton, { BackgroundColor3 = Window.Theme.Accent }, 0.15)
        Tween(TabLabel, { TextColor3 = Color3.fromRGB(255,255,255) }, 0.15)
        if TabIcon then Tween(TabIcon, { ImageColor3 = Color3.fromRGB(255,255,255) }, 0.15) end
        Window.CurrentTab = Tab
    end

    Tab.Label = TabLabel
    Tab.Icon = TabIcon
    Tab._Select = selectTab

    TabButton.MouseButton1Click:Connect(selectTab)

    table.insert(Window.Tabs, Tab)
    if #Window.Tabs == 1 then selectTab() end

    table.insert(Window._ThemeRefreshers, function(Theme)
        if TabPage.Visible then
            TabButton.BackgroundColor3 = Theme.Accent
        else
            TabButton.BackgroundColor3 = Theme.ElementBG
            TabLabel.TextColor3 = Theme.SubText
            if TabIcon then TabIcon.ImageColor3 = Theme.SubText end
        end
        TabPage.ScrollBarImageColor3 = Theme.Accent
    end)

    return Tab
end

----------------------------------------------------------------
-- CreateKeySystem: layar kunci key sebelum hub kebuka
----------------------------------------------------------------
-- Contoh pakai:
--   KitsuneeIsMe:CreateKeySystem({
--       Title    = "KitsuneeIsMe Library",
--       Subtitle = "Masukkan key untuk melanjutkan, " .. game.Players.LocalPlayer.Name,
--       Keys     = {"KITSUNE-LUCKY18"},
--       KeyLink  = "https://link-kamu.com/get-key",
--       SaveKey  = true,
--       Theme    = "Kitsune",
--       OnSuccess = function()
--           local Window = KitsuneeIsMe:CreateWindow({ Name = "Hub Ku", Theme = "Kitsune" })
--           -- ... lanjut bikin tab di sini
--       end,
--   })
function KitsuneeIsMe:CreateKeySystem(config)
    config = config or {}
    local Title     = config.Title or "Key System"
    local Subtitle  = config.Subtitle or "Masukkan key untuk melanjutkan"
    local Note      = config.Note or "Jangan bagikan key kamu ke orang lain."
    local Keys      = config.Keys or (config.Key and { config.Key }) or {}
    local KeyLink   = config.KeyLink
    local SaveKey   = config.SaveKey ~= false
    local FileName  = config.FileName or "KitsuneeIsMe_Key.txt"
    local ThemeName = config.Theme or "Kitsune"
    local Theme     = Themes[ThemeName] or Themes.Kitsune
    local OnSuccess = config.OnSuccess or function() end

    local function isValidKey(input)
        for _, k in ipairs(Keys) do
            if tostring(input):gsub("%s+", "") == tostring(k):gsub("%s+", "") then
                return true
            end
        end
        return false
    end

    -- cek key yang sudah tersimpan (kalau executor support file system)
    local function readSavedKey()
        local ok, result = pcall(function()
            if typeof(isfile) == "function" and isfile(FileName) then
                return readfile(FileName)
            end
        end)
        if ok then return result end
        return nil
    end

    local function saveKey(key)
        if not SaveKey then return end
        pcall(function()
            if typeof(writefile) == "function" then
                writefile(FileName, key)
            end
        end)
    end

    local saved = readSavedKey()
    if saved and isValidKey(saved) then
        OnSuccess()
        return
    end

    -- bersihkan gui key lama kalau ada
    local existing = CoreGui:FindFirstChild("KitsuneeIsMe_KeySystem")
    if existing then existing:Destroy() end

    local ScreenGui = Create("ScreenGui", {
        Name = "KitsuneeIsMe_KeySystem",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        Parent = CoreGui,
    })

    local Backdrop = Create("Frame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 0.45,
        BorderSizePixel = 0,
        Parent = ScreenGui,
    })

    local Panel = Create("Frame", {
        Size = UDim2.fromOffset(340, 240),
        Position = UDim2.new(0.5, -170, 0.5, -120),
        BackgroundColor3 = Theme.Background,
        BorderSizePixel = 0,
        Parent = ScreenGui,
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 12) }),
        Create("UIStroke", { Color = Theme.Stroke, Thickness = 1 }),
    })

    Create("TextLabel", {
        Text = Title,
        Font = Enum.Font.GothamBold,
        TextSize = 18,
        TextColor3 = Theme.Text,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -32, 0, 26),
        Position = UDim2.fromOffset(16, 20),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Panel,
    })

    Create("TextLabel", {
        Text = Subtitle,
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextColor3 = Theme.SubText,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -32, 0, 34),
        Position = UDim2.fromOffset(16, 46),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = Panel,
    })

    local InputBox = Create("TextBox", {
        Size = UDim2.new(1, -32, 0, 38),
        Position = UDim2.fromOffset(16, 92),
        BackgroundColor3 = Theme.ElementBG,
        Text = "",
        PlaceholderText = "Masukkan key di sini...",
        PlaceholderColor3 = Theme.SubText,
        Font = Enum.Font.Gotham,
        TextSize = 14,
        TextColor3 = Theme.Text,
        ClearTextOnFocus = false,
        Parent = Panel,
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 8) }),
        Create("UIPadding", { PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10) }),
    })

    local StatusLabel = Create("TextLabel", {
        Text = Note,
        Font = Enum.Font.Gotham,
        TextSize = 12,
        TextColor3 = Theme.SubText,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -32, 0, 18),
        Position = UDim2.fromOffset(16, 136),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = Panel,
    })

    local SubmitBtn = Create("TextButton", {
        Text = "Unlock",
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundColor3 = Theme.Accent,
        Size = UDim2.new(1, -32, 0, 38),
        Position = UDim2.fromOffset(16, 164),
        AutoButtonColor = false,
        Parent = Panel,
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 8) }),
    })

    SubmitBtn.MouseButton1Click:Connect(function()
        local input = InputBox.Text
        if isValidKey(input) then
            saveKey(input)
            StatusLabel.TextColor3 = Color3.fromRGB(120, 220, 130)
            StatusLabel.Text = "Key benar! Membuka hub..."
            Tween(Panel, { Size = UDim2.fromOffset(340, 0) }, 0.25)
            task.wait(0.3)
            ScreenGui:Destroy()
            OnSuccess()
        else
            StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            StatusLabel.Text = "Key salah, coba lagi."
            Tween(Panel, { Position = Panel.Position + UDim2.fromOffset(8, 0) }, 0.06)
            task.wait(0.06)
            Tween(Panel, { Position = Panel.Position - UDim2.fromOffset(16, 0) }, 0.06)
            task.wait(0.06)
            Tween(Panel, { Position = UDim2.new(0.5, -170, 0.5, -120) }, 0.06)
        end
    end)

    if KeyLink then
        local GetKeyBtn = Create("TextButton", {
            Text = "Get Key",
            Font = Enum.Font.Gotham,
            TextSize = 12,
            TextColor3 = Theme.Accent,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -32, 0, 16),
            Position = UDim2.fromOffset(16, 206),
            Parent = Panel,
        })
        GetKeyBtn.MouseButton1Click:Connect(function()
            local ok = pcall(function()
                setclipboard(KeyLink)
            end)
            StatusLabel.TextColor3 = Theme.SubText
            StatusLabel.Text = ok and "Link disalin ke clipboard!" or KeyLink
        end)
    end

    MakeDraggable(Panel, Panel)
end

