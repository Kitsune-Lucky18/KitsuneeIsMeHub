local WIN_W  = 570
local WIN_H  = 400
local SIDE_W = 158
local HEAD_H = 50
local MINI_W = 42
local MINI_H = 42

function Hub:CreateWindow(opts)
    -- opts: { Name, Subtitle, KeyOpen }
    local winName = opts.Name     or "KitsuneeIsMe Hub"
    local winSub  = opts.Subtitle or "Modern Hub"
    local keyOpen = opts.KeyOpen  or Enum.KeyCode.RightShift

    -- ── ScreenGui ──────────────────────────────────────────
    local sg = mk("ScreenGui", {
        Name            = "KitsuneeIsMe_Hub",
        ResetOnSpawn    = false,
        ZIndexBehavior  = Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset  = true,
    }, lpg)

    -- ── Shadow ─────────────────────────────────────────────
    local shadow = mk("ImageLabel", {
        Size = UDim2.new(0, WIN_W+44, 0, WIN_H+44),
        Position = UDim2.new(0.5, -(WIN_W/2)-22, 0.5, -(WIN_H/2)-16),
        BackgroundTransparency = 1,
        Image = "rbxassetid://6015897843",
        ImageColor3 = Color3.new(0,0,0),
        ImageTransparency = 0.55,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49,49,450,450),
        ZIndex = 0,
        Visible = false,
    }, sg)

    -- ── Main Frame ─────────────────────────────────────────
    local win = mk("Frame", {
        Size      = UDim2.new(0, WIN_W, 0, WIN_H),
        Position  = UDim2.new(0.5, -WIN_W/2, 0.5, -WIN_H/2),
        BackgroundColor3 = T.bg0,
        Active    = true,
        Draggable = true,
        ClipsDescendants = true,
        Visible   = false,
        ZIndex    = 1,
    }, sg)
    corner(win, 14)
    stroke(win, T.bordS, 1)

    -- sync shadow pos when dragged
    win:GetPropertyChangedSignal("AbsolutePosition"):Connect(function()
        shadow.Position = UDim2.new(0, win.AbsolutePosition.X-22, 0, win.AbsolutePosition.Y-16)
    end)

    -- ── Header ─────────────────────────────────────────────
    local header = mk("Frame", {
        Size = UDim2.new(1, 0, 0, HEAD_H),
        BackgroundColor3 = T.bg2,
        BorderSizePixel  = 0,
        ZIndex = 3,
    }, win)

    -- gradient tint
    mk("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, T.acc),
            ColorSequenceKeypoint.new(1, T.bg0),
        }),
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.85),
            NumberSequenceKeypoint.new(1, 1),
        }),
        Rotation = 90,
    }, header)

    -- header bottom line
    mk("Frame", {
        Size = UDim2.new(1,0,0,1), Position = UDim2.new(0,0,1,-1),
        BackgroundColor3 = T.bord, BorderSizePixel = 0, ZIndex = 4,
    }, header)

    -- accent bar left
    local abar = mk("Frame", {
        Size = UDim2.new(0,3,0,30), Position = UDim2.new(0,0,0.5,-15),
        BackgroundColor3 = T.acc, BorderSizePixel = 0, ZIndex = 4,
    }, header)
    corner(abar, 2)

    -- live dot
    local liveDot = mk("Frame", {
        Size = UDim2.new(0,8,0,8), Position = UDim2.new(0,12,0.5,-4),
        BackgroundColor3 = T.green, BorderSizePixel = 0, ZIndex = 4,
    }, header)
    corner(liveDot, 4)
    pulse(liveDot, T.green, Color3.fromRGB(30,90,50), 0.9)

    lbl({ Size=UDim2.new(0,240,0,20), Position=UDim2.new(0,26,0,8),
        Text=winName, Font=Enum.Font.GothamBold, TextSize=15,
        TextColor3=T.t0, ZIndex=4 }, header)

    lbl({ Size=UDim2.new(0,240,0,13), Position=UDim2.new(0,26,0,30),
        Text=winSub, Font=Enum.Font.Gotham, TextSize=10,
        TextColor3=T.t2, ZIndex=4 }, header)

    -- control buttons
    local function ctrlBtn(xOff, txt)
        local b = mk("TextButton", {
            Size=UDim2.new(0,28,0,28), Position=UDim2.new(1,xOff,0.5,-14),
            BackgroundColor3=T.bg3, Text=txt, Font=Enum.Font.GothamBold,
            TextSize=14, TextColor3=T.t1, ZIndex=8,
        }, header)
        corner(b, 8); stroke(b)
        hoverBtn(b, T.bg3, T.bg4)
        return b
    end

    local btnX   = ctrlBtn(-38,  "✕")
    local btnMin = ctrlBtn(-72,  "−")

    -- ── Sidebar ────────────────────────────────────────────
    local sidebar = mk("Frame", {
        Size = UDim2.new(0, SIDE_W, 1, -HEAD_H),
        Position = UDim2.new(0, 0, 0, HEAD_H),
        BackgroundColor3 = T.bg1,
        BorderSizePixel  = 0, ZIndex = 2,
    }, win)

    mk("Frame", {
        Size=UDim2.new(0,1,1,0), Position=UDim2.new(1,-1,0,0),
        BackgroundColor3=T.bord, BorderSizePixel=0, ZIndex=3,
    }, sidebar)

    local tabScroll = mk("ScrollingFrame", {
        Size = UDim2.new(1,0,1,0),
        BackgroundTransparency=1, BorderSizePixel=0,
        ScrollBarThickness=0, CanvasSize=UDim2.new(0,0,0,0),
        ScrollingDirection=Enum.ScrollingDirection.Y,
    }, sidebar)

    local tabList = mk("Frame", {
        Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1,
    }, tabScroll)
    pad(tabList, 10, 8, 10, 8)
    vlist(tabList, 4)

    -- ── Content Area ───────────────────────────────────────
    local contentArea = mk("Frame", {
        Size = UDim2.new(1,-SIDE_W,1,-HEAD_H-22),
        Position = UDim2.new(0,SIDE_W,0,HEAD_H),
        BackgroundTransparency = 1,
        ClipsDescendants = true, ZIndex = 2,
    }, win)

    -- ── Bottom Keybind Hint ────────────────────────────────
    local hintBar = mk("Frame", {
        Size=UDim2.new(1,-SIDE_W,0,22),
        Position=UDim2.new(0,SIDE_W,1,-22),
        BackgroundColor3=T.bg2, BorderSizePixel=0, ZIndex=5,
    }, win)
    mk("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,0,0),
        BackgroundColor3=T.bord,BorderSizePixel=0,ZIndex=5},hintBar)
    lbl({ Size=UDim2.new(1,-20,1,0), Position=UDim2.new(0,14,0,0),
        Text="[ "..tostring(keyOpen).." ] Minimize / Restore  ·  KitsuneeIsMe Hub",
        Font=Enum.Font.Gotham, TextSize=10, TextColor3=T.t2, ZIndex=6 }, hintBar)

    -- ── Minimize Pill ──────────────────────────────────────
    local miniPill = mk("TextButton", {
        Size=UDim2.new(0,MINI_W,0,MINI_H),
        Position=UDim2.new(0.5,-MINI_W/2,0.5,-MINI_H/2),
        BackgroundColor3=T.bg2, Text="", ZIndex=20, Visible=false,
    }, sg)
    corner(miniPill, 13)
    stroke(miniPill, T.bord, 1)

    local miniIcon = lbl({
        Size=UDim2.new(1,0,1,0), Text="K",
        Font=Enum.Font.GothamBold, TextSize=18,
        TextColor3=T.acc, TextXAlignment=Enum.TextXAlignment.Center,
        ZIndex=21,
    }, miniPill)
    -- pulse mini icon color
    task.spawn(function()
        while miniPill.Parent do
            if miniPill.Visible then
                tw(miniIcon, TweenInfo.new(1), { TextColor3=T.accD })
                task.wait(1)
                tw(miniIcon, TweenInfo.new(1), { TextColor3=T.acc })
                task.wait(1)
            else task.wait(0.5) end
        end
    end)

    -- ── Open / Close / Minimize ────────────────────────────
    local isOpen = false
    local isMini = false

    local function openWin()
        isOpen=true; isMini=false
        win.Visible=true; shadow.Visible=true; miniPill.Visible=false
        win.Size=UDim2.new(0,WIN_W*.78,0,WIN_H*.78)
        win.BackgroundTransparency=1; shadow.ImageTransparency=1
        tw(win, TI.spring, { Size=UDim2.new(0,WIN_W,0,WIN_H), BackgroundTransparency=0 })
        tw(shadow, TI.med, { ImageTransparency=0.55 })
        Notify({ Title="KitsuneeIsMe Hub", Content="Hub dimuat! Selamat datang.", Type="success", Duration=3 })
    end

    local function closeWin()
        isOpen=false
        tw(win, TI.med, { Size=UDim2.new(0,WIN_W*.82,0,WIN_H*.82), BackgroundTransparency=1 })
        tw(shadow, TI.med, { ImageTransparency=1 })
        task.delay(0.28, function() win.Visible=false; shadow.Visible=false end)
    end

    local function minimizeWin()
        isMini=true; shadow.Visible=false
        tw(win, TI.med, { Size=UDim2.new(0,WIN_W*.65,0,0), BackgroundTransparency=1 })
        task.delay(0.26, function()
            win.Visible=false; miniPill.Visible=true
            miniPill.Size=UDim2.new(0,MINI_W*.5,0,MINI_H*.5)
            tw(miniPill, TI.bounce, { Size=UDim2.new(0,MINI_W,0,MINI_H) })
        end)
    end

    local function restoreWin()
        isMini=false; miniPill.Visible=false
        win.Visible=true; shadow.Visible=true
        win.Size=UDim2.new(0,WIN_W*.65,0,0); win.BackgroundTransparency=1
        tw(win, TI.spring, { Size=UDim2.new(0,WIN_W,0,WIN_H), BackgroundTransparency=0 })
        tw(shadow, TI.med, { ImageTransparency=0.55 })
    end

    btnX.MouseButton1Click:Connect(closeWin)
    btnMin.MouseButton1Click:Connect(minimizeWin)
    miniPill.MouseButton1Click:Connect(restoreWin)

    UserInputService.InputBegan:Connect(function(inp, gpe)
        if gpe then return end
        if inp.KeyCode == keyOpen then
            if isOpen and not isMini then minimizeWin()
            elseif isMini then restoreWin()
            else openWin() end
        end
    end)

    -- ── Tab System ─────────────────────────────────────────
    local tabs       = {}
    local activeTab  = nil
    local tabCount   = 0

    local Window = {}
    Window._sg   = sg
    Window._win  = win

    -- ────────────────────────────────────────────────────────
    --  Window:CreateTab(name, icon)
    -- ────────────────────────────────────────────────────────
    function Window:CreateTab(name, icon)
        tabCount += 1
        local tabId = name..tabCount

        -- sidebar button
        local btn = mk("TextButton", {
            Size=UDim2.new(1,0,0,40),
            BackgroundColor3=T.bg1,
            Text="", LayoutOrder=tabCount, ZIndex=5,
        }, tabList)
        corner(btn, 10)

        -- active indicator
        local indic = mk("Frame", {
            Size=UDim2.new(0,3,0.65,0),
            Position=UDim2.new(0,0,0.175,0),
            BackgroundColor3=T.acc,
            BackgroundTransparency=1,
            BorderSizePixel=0, ZIndex=6,
        }, btn)
        corner(indic, 2)

        local iconL = lbl({
            Size=UDim2.new(0,24,1,0), Position=UDim2.new(0,10,0,0),
            Text=icon or "•", TextSize=16, TextColor3=T.t2,
            TextXAlignment=Enum.TextXAlignment.Center, ZIndex=6,
        }, btn)

        local nameL = lbl({
            Size=UDim2.new(1,-38,1,0), Position=UDim2.new(0,38,0,0),
            Text=name, Font=Enum.Font.Gotham, TextSize=12,
            TextColor3=T.t2, ZIndex=6,
        }, btn)

        -- update sidebar canvas height
        tabScroll.CanvasSize = UDim2.new(0,0,0, tabCount * 48 + 20)

        -- page (scroll frame per tab)
        local page = mk("ScrollingFrame", {
            Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1, BorderSizePixel=0,
            ScrollBarThickness=3, ScrollBarImageColor3=T.acc,
            ScrollingDirection=Enum.ScrollingDirection.Y,
            CanvasSize=UDim2.new(0,0,0,0),
            Visible=false, ZIndex=2,
        }, contentArea)

        local inner = mk("Frame", {
            Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1, ZIndex=2,
        }, page)
        pad(inner, 12, 14, 14, 14)
        vlist(inner, 8, Enum.HorizontalAlignment.Left)

        local elemCount = 0

        local function updateCanvas()
            page.CanvasSize = UDim2.new(0,0,0, elemCount * 58 + 24)
        end

        -- activate this tab
        local function activate()
            -- deactivate all
            for _, t in pairs(tabs) do
                tw(t.btn,   TI.fast, { BackgroundColor3=T.bg1 })
                tw(t.indic, TI.fast, { BackgroundTransparency=1 })
                tw(t.iconL, TI.fast, { TextColor3=T.t2 })
                tw(t.nameL, TI.fast, { TextColor3=T.t2 })
                t.page.Visible = false
            end
            activeTab = tabId
            tw(btn,   TI.fast, { BackgroundColor3=T.bghov })
            tw(indic, TI.fast, { BackgroundTransparency=0 })
            tw(iconL, TI.fast, { TextColor3=T.acc })
            tw(nameL, TI.fast, { TextColor3=T.t0 })
            page.Visible = true
        end

        btn.MouseButton1Click:Connect(activate)
        hoverBtn(btn, T.bg1, T.bg3)
        -- hover doesn't override active
        btn.MouseEnter:Connect(function()
            if activeTab ~= tabId then tw(btn, TI.fast, { BackgroundColor3=T.bg3 }) end
        end)
        btn.MouseLeave:Connect(function()
            if activeTab ~= tabId then tw(btn, TI.fast, { BackgroundColor3=T.bg1 }) end
        end)

        if tabCount == 1 then activate() end

        local tabData = {
            btn=btn, indic=indic, iconL=iconL, nameL=nameL,
            page=page, inner=inner, activate=activate,
        }
        tabs[tabId] = tabData

        local Tab = {}

        -- ──────────────────────────────────────────────────
        --  Tab:CreateSection(name)
        -- ──────────────────────────────────────────────────
        function Tab:CreateSection(name)
            elemCount += 1
            local row = mk("Frame", {
                Size=UDim2.new(1,0,0,26),
                BackgroundTransparency=1, LayoutOrder=elemCount,
            }, inner)

            mk("Frame", {
                Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,0.5,0),
                BackgroundColor3=T.bord, BorderSizePixel=0,
            }, row)

            local pill = mk("Frame", {
                Size=UDim2.new(0,0,1,0),
                AutomaticSize=Enum.AutomaticSize.X,
                BackgroundColor3=T.bg3, BorderSizePixel=0,
                Position=UDim2.new(0,4,0,0),
            }, row)
            corner(pill, 4)
            pad(pill, 0, 8, 0, 8)

            lbl({ Size=UDim2.new(0,0,1,0), AutomaticSize=Enum.AutomaticSize.X,
                Text=name, Font=Enum.Font.GothamBold, TextSize=10,
                TextColor3=T.t2 }, pill)

            updateCanvas()
        end

        -- ──────────────────────────────────────────────────
        --  Tab:CreateSeparator()
        -- ──────────────────────────────────────────────────
        function Tab:CreateSeparator()
            elemCount += 1
            mk("Frame", {
                Size=UDim2.new(1,0,0,1),
                BackgroundColor3=T.bord, BorderSizePixel=0,
                LayoutOrder=elemCount,
            }, inner)
            updateCanvas()
        end

        -- ──────────────────────────────────────────────────
        --  Tab:CreateLabel(text)
        -- ──────────────────────────────────────────────────
        function Tab:CreateLabel(text)
            elemCount += 1
            lbl({
                Size=UDim2.new(1,0,0,22),
                Text=text, Font=Enum.Font.Gotham, TextSize=12,
                TextColor3=T.t1, TextWrapped=true,
                LayoutOrder=elemCount,
            }, inner)
            updateCanvas()
        end

        -- ──────────────────────────────────────────────────
        --  Tab:CreateToggle({ Name, Description, Default, Callback })
        -- ──────────────────────────────────────────────────
        function Tab:CreateToggle(opts)
            elemCount += 1
            local state = opts.Default or false
            local cb    = opts.Callback or function() end

            local row = mk("Frame", {
                Size=UDim2.new(1,0,0,52),
                BackgroundColor3=T.bg3, LayoutOrder=elemCount, ZIndex=3,
            }, inner)
            corner(row, 10); stroke(row, T.bord)

            -- left accent strip
            local strip = mk("Frame", {
                Size=UDim2.new(0,3,0.65,0), Position=UDim2.new(0,0,0.175,0),
                BackgroundColor3=T.acc, BackgroundTransparency=1,
                BorderSizePixel=0, ZIndex=4,
            }, row)
            corner(strip, 2)

            lbl({ Size=UDim2.new(1,-72,0,18), Position=UDim2.new(0,14,0,9),
                Text=opts.Name, Font=Enum.Font.GothamBold, TextSize=13,
                TextColor3=T.t0, ZIndex=4 }, row)

            if opts.Description then
                lbl({ Size=UDim2.new(1,-72,0,14), Position=UDim2.new(0,14,0,29),
                    Text=opts.Description, Font=Enum.Font.Gotham, TextSize=10,
                    TextColor3=T.t2, ZIndex=4, TextWrapped=true }, row)
            end

            -- switch
            local track = mk("Frame", {
                Size=UDim2.new(0,46,0,26), Position=UDim2.new(1,-58,0.5,-13),
                BackgroundColor3=T.bord, BorderSizePixel=0, ZIndex=5,
            }, row)
            corner(track, 13)

            local thumb = mk("Frame", {
                Size=UDim2.new(0,20,0,20), Position=UDim2.new(0,3,0.5,-10),
                BackgroundColor3=T.t2, BorderSizePixel=0, ZIndex=6,
            }, track)
            corner(thumb, 10)

            local function apply(s, anim)
                local ti = anim and TI.fast or TweenInfo.new(0)
                if s then
                    tw(track, ti, { BackgroundColor3=T.acc })
                    tw(thumb, ti, { Position=UDim2.new(0,23,0.5,-10), BackgroundColor3=T.white })
                    tw(row,   ti, { BackgroundColor3=T.bghov })
                    tw(strip, ti, { BackgroundTransparency=0 })
                else
                    tw(track, ti, { BackgroundColor3=T.bord })
                    tw(thumb, ti, { Position=UDim2.new(0,3,0.5,-10), BackgroundColor3=T.t2 })
                    tw(row,   ti, { BackgroundColor3=T.bg3 })
                    tw(strip, ti, { BackgroundTransparency=1 })
                end
            end
            apply(state, false)

            local hit = mk("TextButton", {
                Size=UDim2.new(1,0,1,0), BackgroundTransparency=1, Text="", ZIndex=9,
            }, row)

            hit.MouseButton1Click:Connect(function()
                state = not state
                apply(state, true)
                pcall(cb, state)
            end)
            hit.MouseEnter:Connect(function()
                if not state then tw(row, TI.fast, { BackgroundColor3=Color3.fromRGB(24,24,34) }) end
            end)
            hit.MouseLeave:Connect(function()
                if not state then tw(row, TI.fast, { BackgroundColor3=T.bg3 }) end
            end)

            updateCanvas()

            -- return controller
            local Toggle = {}
            function Toggle:Set(v) state=v; apply(v,true); pcall(cb,v) end
            function Toggle:Get() return state end
            return Toggle
        end

        -- ──────────────────────────────────────────────────
        --  Tab:CreateButton({ Name, Description, Text, Callback })
        -- ──────────────────────────────────────────────────
        function Tab:CreateButton(opts)
            elemCount += 1
            local cb = opts.Callback or function() end

            local row = mk("Frame", {
                Size=UDim2.new(1,0,0,52),
                BackgroundColor3=T.bg3, LayoutOrder=elemCount, ZIndex=3,
            }, inner)
            corner(row, 10); stroke(row, T.bord)

            lbl({ Size=UDim2.new(1,-110,0,18), Position=UDim2.new(0,14,0,9),
                Text=opts.Name, Font=Enum.Font.GothamBold, TextSize=13,
                TextColor3=T.t0, ZIndex=4 }, row)

            if opts.Description then
                lbl({ Size=UDim2.new(1,-110,0,14), Position=UDim2.new(0,14,0,29),
                    Text=opts.Description, Font=Enum.Font.Gotham, TextSize=10,
                    TextColor3=T.t2, ZIndex=4 }, row)
            end

            local execBtn = mk("TextButton", {
                Size=UDim2.new(0,84,0,30), Position=UDim2.new(1,-96,0.5,-15),
                BackgroundColor3=T.acc, Text=opts.Text or "Execute",
                Font=Enum.Font.GothamBold, TextSize=12, TextColor3=T.white, ZIndex=6,
            }, row)
            corner(execBtn, 8)

            execBtn.MouseButton1Click:Connect(function()
                tw(execBtn, TI.fast, { BackgroundColor3=T.accD })
                task.delay(0.14, function() tw(execBtn, TI.fast, { BackgroundColor3=T.acc }) end)
                pcall(cb)
            end)
            hoverBtn(execBtn, T.acc, Color3.fromRGB(130,185,255))

            updateCanvas()
        end

        -- ──────────────────────────────────────────────────
        --  Tab:CreateSlider({ Name, Description, Min, Max, Default, Callback })
        -- ──────────────────────────────────────────────────
        function Tab:CreateSlider(opts)
            elemCount += 1
            local minV = opts.Min     or 0
            local maxV = opts.Max     or 100
            local val  = opts.Default or minV
            local cb   = opts.Callback or function() end

            local row = mk("Frame", {
                Size=UDim2.new(1,0,0,62),
                BackgroundColor3=T.bg3, LayoutOrder=elemCount, ZIndex=3,
            }, inner)
            corner(row, 10); stroke(row, T.bord)

            lbl({ Size=UDim2.new(1,-80,0,18), Position=UDim2.new(0,14,0,8),
                Text=opts.Name, Font=Enum.Font.GothamBold, TextSize=13,
                TextColor3=T.t0, ZIndex=4 }, row)

            if opts.Description then
                lbl({ Size=UDim2.new(1,-80,0,13), Position=UDim2.new(0,14,0,26),
                    Text=opts.Description, Font=Enum.Font.Gotham, TextSize=10,
                    TextColor3=T.t2, ZIndex=4 }, row)
            end

            local valLbl = lbl({
                Size=UDim2.new(0,60,0,18), Position=UDim2.new(1,-72,0,8),
                Text=tostring(val), Font=Enum.Font.GothamBold, TextSize=13,
                TextColor3=T.acc, TextXAlignment=Enum.TextXAlignment.Right, ZIndex=4,
            }, row)

            local trackBg = mk("Frame", {
                Size=UDim2.new(1,-28,0,6), Position=UDim2.new(0,14,0,46),
                BackgroundColor3=T.bord, BorderSizePixel=0, ZIndex=4,
            }, row)
            corner(trackBg, 3)

            local fill = mk("Frame", {
                Size=UDim2.new(0,0,1,0), BackgroundColor3=T.acc,
                BorderSizePixel=0, ZIndex=5,
            }, trackBg)
            corner(fill, 3)

            local thumb2 = mk("Frame", {
                Size=UDim2.new(0,14,0,14),
                AnchorPoint=Vector2.new(0.5,0.5),
                Position=UDim2.new(0,0,0.5,0),
                BackgroundColor3=T.white, BorderSizePixel=0, ZIndex=6,
            }, trackBg)
            corner(thumb2, 7)
            stroke(thumb2, T.acc, 2)

            local function setVal(v)
                v = math.clamp(math.round(v), minV, maxV)
                val = v
                local pct = (v-minV)/(maxV-minV)
                tw(fill,   TI.fast, { Size=UDim2.new(pct,0,1,0) })
                tw(thumb2, TI.fast, { Position=UDim2.new(pct,0,0.5,0) })
                valLbl.Text = tostring(v)
                pcall(cb, v)
            end
            setVal(val)

            local dragging = false
            trackBg.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then
                    local abs = trackBg.AbsolutePosition
                    local sz  = trackBg.AbsoluteSize
                    local rx  = math.clamp((i.Position.X-abs.X)/sz.X, 0, 1)
                    setVal(minV + rx*(maxV-minV))
                end
            end)

            updateCanvas()

            local Slider = {}
            function Slider:Set(v) setVal(v) end
            function Slider:Get() return val end
            return Slider
        end

        -- ──────────────────────────────────────────────────
        --  Tab:CreateInput({ Name, Description, Placeholder, Callback })
        -- ──────────────────────────────────────────────────
        function Tab:CreateInput(opts)
            elemCount += 1
            local cb = opts.Callback or function() end

            local row = mk("Frame", {
                Size=UDim2.new(1,0,0,52),
                BackgroundColor3=T.bg3, LayoutOrder=elemCount, ZIndex=3,
            }, inner)
            corner(row, 10); stroke(row, T.bord)

            lbl({ Size=UDim2.new(1,-14,0,18), Position=UDim2.new(0,14,0,8),
                Text=opts.Name, Font=Enum.Font.GothamBold, TextSize=13,
                TextColor3=T.t0, ZIndex=4 }, row)

            local box = mk("TextBox", {
                Size=UDim2.new(1,-28,0,22), Position=UDim2.new(0,14,0,26),
                BackgroundColor3=T.bg2, BorderSizePixel=0,
                Text="", PlaceholderText=opts.Placeholder or "Type here…",
                Font=Enum.Font.Gotham, TextSize=12,
                TextColor3=T.t0, PlaceholderColor3=T.t2,
                ClearTextOnFocus=false, ZIndex=5,
            }, row)
            corner(box, 6); stroke(box, T.bord)
            pad(box, 0, 8, 0, 8)

            box.FocusLost:Connect(function(enter)
                if enter then pcall(cb, box.Text) end
            end)
            box.Focused:Connect(function()
                tw(box, TI.fast, { BackgroundColor3=T.bg4 })
            end)
            box.FocusLost:Connect(function()
                tw(box, TI.fast, { BackgroundColor3=T.bg2 })
            end)

            updateCanvas()

            local Input = {}
            function Input:Set(v) box.Text=v end
            function Input:Get() return box.Text end
            return Input
        end

        -- ──────────────────────────────────────────────────
        --  Tab:CreateDropdown({ Name, Options, Default, Callback })
        -- ──────────────────────────────────────────────────
        function Tab:CreateDropdown(opts)
            elemCount += 1
            local options = opts.Options  or {}
            local selVal  = opts.Default  or (options[1] or "")
            local cb      = opts.Callback or function() end
            local ddOpen  = false

            local container = mk("Frame", {
                Size=UDim2.new(1,0,0,52),
                BackgroundColor3=T.bg3, LayoutOrder=elemCount, ZIndex=3,
                ClipsDescendants=false,
            }, inner)
            corner(container, 10); stroke(container, T.bord)

            lbl({ Size=UDim2.new(1,-14,0,18), Position=UDim2.new(0,14,0,8),
                Text=opts.Name, Font=Enum.Font.GothamBold, TextSize=13,
                TextColor3=T.t0, ZIndex=4 }, container)

            local selBtn = mk("TextButton", {
                Size=UDim2.new(1,-28,0,22), Position=UDim2.new(0,14,0,26),
                BackgroundColor3=T.bg2, Text=selVal,
                Font=Enum.Font.Gotham, TextSize=12,
                TextColor3=T.t0, ZIndex=5,
            }, container)
            corner(selBtn, 6); stroke(selBtn, T.bord)
            pad(selBtn, 0, 26, 0, 8)

            lbl({ Size=UDim2.new(0,20,0,22), Position=UDim2.new(1,-22,0,0),
                Text="▾", TextSize=12, TextColor3=T.t2,
                TextXAlignment=Enum.TextXAlignment.Center,
                ZIndex=6 }, selBtn)

            -- dropdown list
            local ddFrame = mk("Frame", {
                Size=UDim2.new(1,-28,0,0),
                Position=UDim2.new(0,14,0,52),
                BackgroundColor3=T.bg2, ZIndex=10,
                ClipsDescendants=true, Visible=false,
            }, container)
            corner(ddFrame, 8); stroke(ddFrame, T.bord)

            local ddInner = mk("Frame",{
                Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1, ZIndex=10,
            }, ddFrame)
            pad(ddInner, 4, 4, 4, 4)
            vlist(ddInner, 3)

            for _, opt in ipairs(options) do
                local optBtn = mk("TextButton", {
                    Size=UDim2.new(1,0,0,26),
                    BackgroundColor3=T.bg3, Text=opt,
                    Font=Enum.Font.Gotham, TextSize=12,
                    TextColor3=T.t1, ZIndex=11,
                }, ddInner)
                corner(optBtn, 6)
                optBtn.MouseButton1Click:Connect(function()
                    selVal = opt
                    selBtn.Text = opt
                    ddOpen = false
                    ddFrame.Visible = false
                    tw(ddFrame, TI.fast, { Size=UDim2.new(1,-28,0,0) })
                    tw(container, TI.fast, { Size=UDim2.new(1,0,0,52) })
                    pcall(cb, opt)
                end)
                hoverBtn(optBtn, T.bg3, T.bg4)
            end

            local optH = #options * 30 + 8
            selBtn.MouseButton1Click:Connect(function()
                ddOpen = not ddOpen
                ddFrame.Visible = true
                tw(ddFrame, TI.med, { Size=UDim2.new(1,-28,0, ddOpen and optH or 0) })
                tw(container, TI.med, { Size=UDim2.new(1,0,0, ddOpen and 52+optH+4 or 52) })
                if not ddOpen then task.delay(0.28, function() ddFrame.Visible=false end) end
            end)

            updateCanvas()

            local DD = {}
            function DD:Set(v) selVal=v; selBtn.Text=v; pcall(cb,v) end
            function DD:Get() return selVal end
            return DD
        end

        return Tab
    end

    -- open on create
    task.delay(0.6, openWin)

    return Window
end

