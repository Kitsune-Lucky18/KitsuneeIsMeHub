local T = {
    -- backgrounds
    bg0    = Color3.fromRGB(9,   9,  13),
    bg1    = Color3.fromRGB(14,  14,  20),
    bg2    = Color3.fromRGB(19,  19,  27),
    bg3    = Color3.fromRGB(24,  24,  34),
