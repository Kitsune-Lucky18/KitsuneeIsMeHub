local notifSG = mk("ScreenGui", {
    Name = "KitsuneeIsMe_Notifs",
    ResetOnSpawn = false,
    ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
}, lpg)

local notifHolder = mk("Frame", {
    Size = UDim2.new(0, 290, 1, -20),
    Position = UDim2.new(1, -305, 0, 10),
    BackgroundTransparency = 1,
    AnchorPoint = Vector2.new(0, 0),
}, notifSG)
vlist(notifHolder, 8)

local function Notify(opts)
    -- opts: { Title, Content, Type, Duration }
    -- Type: "success" | "error" | "warning" | "info"
    local typ  = opts.Type     or "info"
    local dur  = opts.Duration or 3.5
    local col  = typ == "success" and T.green
              or typ == "error"   and T.red
              or typ == "warning" and T.yellow
              or T.acc

    local card = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 68),
        BackgroundColor3 = T.bg2,
        ClipsDescendants = true,
        LayoutOrder = tick(),
    }, notifHolder)
    corner(card, 11)
    stroke(card, T.bord)

    -- left strip
    local strip = mk("Frame", {
        Size = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = col,
        BorderSizePixel = 0,
    }, card)
    corner(strip, 2)

    -- glow dot
    local gdot = mk("Frame", {
        Size = UDim2.new(0, 8, 0, 8),
        Position = UDim2.new(0, 13, 0, 14),
        BackgroundColor3 = col,
        BorderSizePixel = 0,
    }, card)
    corner(gdot, 4)
    pulse(gdot, col, Color3.new(col.R*.4, col.G*.4, col.B*.4), 0.6)

    lbl({ Size=UDim2.new(1,-32,0,18), Position=UDim2.new(0,27,0,10),
        Text=opts.Title or "Hub", Font=Enum.Font.GothamBold, TextSize=13, TextColor3=T.t0 }, card)
    lbl({ Size=UDim2.new(1,-32,0,28), Position=UDim2.new(0,27,0,30),
        Text=opts.Content or "", Font=Enum.Font.Gotham, TextSize=11,
        TextColor3=T.t1, TextWrapped=true }, card)

    -- progress bar
    local bar = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0,0,1,-2),
        BackgroundColor3 = col,
        BorderSizePixel = 0,
    }, card)

    -- slide in
    card.Position = UDim2.new(1, 12, 0, 0)
    tw(card, TI.spring, { Position = UDim2.new(0, 0, 0, 0) })
    tw(bar, TweenInfo.new(dur, Enum.EasingStyle.Linear), { Size = UDim2.new(0,0,0,2) })

    task.delay(dur, function()
        tw(card, TI.med, { Position = UDim2.new(1, 12, 0, 0) })
        task.wait(0.3)
        card:Destroy()
    end)
end

Hub.Notify = Notify

