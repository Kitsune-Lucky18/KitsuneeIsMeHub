        self._Minimized = true
        MinimizeBtn.Text = "+"
        TabListBG.Visible = false
        ContentArea.Visible = false
        Tween(Main, { Size = UDim2.new(0, self._OriginalSize.X.Offset, 0, 44) }, 0.2)
