            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    setFromX(input.Position.X)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)
        end

        makeChannel("R", "R")
        makeChannel("G", "G")
        makeChannel("B", "B")

        KitsuneeIsMe._FlagSetters[Flag] = function(v)
            currentColor.R = math.floor(v.R * 255)
            currentColor.G = math.floor(v.G * 255)
            currentColor.B = math.floor(v.B * 255)
            Swatch.BackgroundColor3 = v
            for _, key in ipairs({ "R", "G", "B" }) do
                local ref = channelRefs[key]
                if ref then
                    ref.Fill.Size = UDim2.fromScale(currentColor[key] / 255, 1)
                    ref.ValLbl.Text = tostring(currentColor[key])
                end
            end
            KitsuneeIsMe.Flags[Flag] = v
        end

        local open = false
        Head.MouseButton1Click:Connect(function()
            open = not open
            if open then
                Tween(Holder, { Size = UDim2.new(1, 0, 0, 134) }, 0.2)
            else
