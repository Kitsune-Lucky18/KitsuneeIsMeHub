                Parent = Row,
            })
            channelRefs[key] = { Fill = Fill, ValLbl = ValLbl, Bar = Bar }

            local dragging = false
            local function setFromX(xpos)
                local rel = math.clamp((xpos - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
                currentColor[key] = math.floor(rel * 255)
                Fill.Size = UDim2.fromScale(rel, 1)
                ValLbl.Text = tostring(currentColor[key])
                local newColor = Color3.fromRGB(currentColor.R, currentColor.G, currentColor.B)
                Swatch.BackgroundColor3 = newColor
                KitsuneeIsMe.Flags[Flag] = newColor
                pcall(Callback, newColor)
            end

            Bar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    setFromX(input.Position.X)
                end
