function MyHub:CreateTab(name)
    local Window = self

    local TabButton = Create("TextButton", {
        Size = UDim2.new(1, 0, 0, 32),
        BackgroundColor3 = Window.Theme.ElementBG,
        Text = name,
        Font = Enum.Font.Gotham,
        TextSize = 14,
        TextColor3 = Window.Theme.SubText,
        AutoButtonColor = false,
        Parent = Window._TabList,
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
    })

    local TabPage = Create("ScrollingFrame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Window.Theme.Accent,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        Parent = Window._ContentArea,
    }, {
        Create("UIListLayout", { Padding = UDim.new(0, 8) }),
        Create("UIPadding", {
            PaddingLeft = UDim.new(0, 4), PaddingRight = UDim.new(0, 8),
            PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 12),
        }),
    })

    local Tab = { Button = TabButton, Page = TabPage, Window = Window }

    local function selectTab()
        for _, t in ipairs(Window.Tabs) do
            t.Page.Visible = false
            Tween(t.Button, { BackgroundColor3 = Window.Theme.ElementBG, TextColor3 = Window.Theme.SubText }, 0.15)
        end
        TabPage.Visible = true
        Tween(TabButton, { BackgroundColor3 = Window.Theme.Accent, TextColor3 = Color3.fromRGB(255,255,255) }, 0.15)
        Window.CurrentTab = Tab
    end

    TabButton.MouseButton1Click:Connect(selectTab)

    table.insert(Window.Tabs, Tab)
    if #Window.Tabs == 1 then selectTab() end

    table.insert(Window._ThemeRefreshers, function(Theme)
        if TabPage.Visible then
            TabButton.BackgroundColor3 = Theme.Accent
        else
            TabButton.BackgroundColor3 = Theme.ElementBG
            TabButton.TextColor3 = Theme.SubText
        end
        TabPage.ScrollBarImageColor3 = Theme.Accent
    end)

    ------------------------------------------------------------
    -- Tab:CreateSection (judul pemisah)
    ------------------------------------------------------------
    function Tab:CreateSection(title)
        Create("TextLabel", {
            Text = title,
            Font = Enum.Font.GothamBold,
            TextSize = 13,
            TextColor3 = Window.Theme.SubText,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 20),
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = TabPage,
        })
    end

    ------------------------------------------------------------
    -- Tab:CreateLabel
    ------------------------------------------------------------
    function Tab:CreateLabel(text)
        local lbl = Create("TextLabel", {
            Text = text,
            Font = Enum.Font.Gotham,
            TextSize = 13,
            TextColor3 = Window.Theme.Text,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 18),
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
            Parent = TabPage,
        })
        table.insert(Window._ThemeRefreshers, function(Theme) lbl.TextColor3 = Theme.Text end)
        return lbl
    end

    ------------------------------------------------------------
    -- Tab:CreateButton
    ------------------------------------------------------------
    function Tab:CreateButton(config)
        config = config or {}
        local Text = config.Name or "Button"
        local Callback = config.Callback or function() end

        local Btn = Create("TextButton", {
            Size = UDim2.new(1, 0, 0, 36),
            BackgroundColor3 = Window.Theme.ElementBG,
            Text = Text,
            Font = Enum.Font.Gotham,
            TextSize = 14,
            TextColor3 = Window.Theme.Text,
            AutoButtonColor = false,
            Parent = TabPage,
        }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
        })

        Btn.MouseEnter:Connect(function()
            Tween(Btn, { BackgroundColor3 = Window.Theme.Accent }, 0.15)
        end)
        Btn.MouseLeave:Connect(function()
            Tween(Btn, { BackgroundColor3 = Window.Theme.ElementBG }, 0.15)
        end)
        Btn.MouseButton1Click:Connect(function()
            pcall(Callback)
        end)

        table.insert(Window._ThemeRefreshers, function(Theme)
            Btn.BackgroundColor3 = Theme.ElementBG
            Btn.TextColor3 = Theme.Text
        end)

        return Btn
    end

    ------------------------------------------------------------
    -- Tab:CreateToggle
    ------------------------------------------------------------
    function Tab:CreateToggle(config)
        config = config or {}
        local Text = config.Name or "Toggle"
        local Default = config.Default or false
        local Flag = config.Flag or Text
        local Callback = config.Callback or function() end

        local Holder = Create("Frame", {
            Size = UDim2.new(1, 0, 0, 36),
            BackgroundColor3 = Window.Theme.ElementBG,
            Parent = TabPage,
        }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
        })

        Create("TextLabel", {
            Text = Text,
            Font = Enum.Font.Gotham,
            TextSize = 14,
            TextColor3 = Window.Theme.Text,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -60, 1, 0),
            Position = UDim2.fromOffset(12, 0),
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = Holder,
        })

        local Switch = Create("Frame", {
            Size = UDim2.fromOffset(40, 20),
            Position = UDim2.new(1, -52, 0.5, -10),
            BackgroundColor3 = Window.Theme.Stroke,
            Parent = Holder,
        }, {
            Create("UICorner", { CornerRadius = UDim.new(1, 0) }),
        })

        local Knob = Create("Frame", {
            Size = UDim2.fromOffset(16, 16),
            Position = UDim2.fromOffset(2, 2),
            BackgroundColor3 = Color3.fromRGB(255, 255, 255),
            Parent = Switch,
        }, {
            Create("UICorner", { CornerRadius = UDim.new(1, 0) }),
        })

        local state = Default
        local function render(instant)
            local t = instant and 0 or 0.15
            if state then
                Tween(Switch, { BackgroundColor3 = Window.Theme.Accent }, t)
                Tween(Knob, { Position = UDim2.fromOffset(22, 2) }, t)
            else
                Tween(Switch, { BackgroundColor3 = Window.Theme.Stroke }, t)
                Tween(Knob, { Position = UDim2.fromOffset(2, 2) }, t)
            end
        end
        render(true)
        MyHub.Flags[Flag] = state

        local clickArea = Create("TextButton", {
            Size = UDim2.fromScale(1, 1),
            BackgroundTransparency = 1,
            Text = "",
            Parent = Holder,
        })
        clickArea.MouseButton1Click:Connect(function()
            state = not state
            MyHub.Flags[Flag] = state
            render()
            pcall(Callback, state)
        end)

        table.insert(Window._ThemeRefreshers, function(Theme)
            Holder.BackgroundColor3 = Theme.ElementBG
            render(true)
        end)

        return { Set = function(_, v) state = v; MyHub.Flags[Flag] = v; render() end }
    end

    ------------------------------------------------------------
    -- Tab:CreateSlider
    ------------------------------------------------------------
    function Tab:CreateSlider(config)
        config = config or {}
        local Text = config.Name or "Slider"
        local Min = config.Min or 0
        local Max = config.Max or 100
        local Default = math.clamp(config.Default or Min, Min, Max)
        local Flag = config.Flag or Text
        local Callback = config.Callback or function() end

        local Holder = Create("Frame", {
            Size = UDim2.new(1, 0, 0, 46),
            BackgroundColor3 = Window.Theme.ElementBG,
            Parent = TabPage,
        }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
        })

        local Label = Create("TextLabel", {
            Text = Text,
            Font = Enum.Font.Gotham,
            TextSize = 14,
            TextColor3 = Window.Theme.Text,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -60, 0, 20),
            Position = UDim2.fromOffset(12, 4),
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = Holder,
        })

        local ValueLabel = Create("TextLabel", {
            Text = tostring(Default),
            Font = Enum.Font.GothamBold,
            TextSize = 13,
            TextColor3 = Window.Theme.SubText,
            BackgroundTransparency = 1,
            Size = UDim2.fromOffset(50, 20),
            Position = UDim2.new(1, -58, 0, 4),
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent = Holder,
        })

        local Bar = Create("Frame", {
            Size = UDim2.new(1, -24, 0, 6),
            Position = UDim2.fromOffset(12, 30),
            BackgroundColor3 = Window.Theme.Stroke,
            Parent = Holder,
        }, {
            Create("UICorner", { CornerRadius = UDim.new(1, 0) }),
        })

        local Fill = Create("Frame", {
            Size = UDim2.fromScale((Default - Min) / (Max - Min), 1),
            BackgroundColor3 = Window.Theme.Accent,
            Parent = Bar,
        }, {
            Create("UICorner", { CornerRadius = UDim.new(1, 0) }),
        })

        local dragging = false
        local function setFromX(xpos)
            local rel = math.clamp((xpos - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
            local value = math.floor(Min + (Max - Min) * rel)
            Fill.Size = UDim2.fromScale(rel, 1)
            ValueLabel.Text = tostring(value)
            MyHub.Flags[Flag] = value
            pcall(Callback, value)
        end

        Bar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                setFromX(input.Position.X)
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                setFromX(input.Position.X)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)

        MyHub.Flags[Flag] = Default

        table.insert(Window._ThemeRefreshers, function(Theme)
            Holder.BackgroundColor3 = Theme.ElementBG
            Label.TextColor3 = Theme.Text
            Bar.BackgroundColor3 = Theme.Stroke
            Fill.BackgroundColor3 = Theme.Accent
        end)

        return Holder
    end

    ------------------------------------------------------------
    -- Tab:CreateDropdown
    ------------------------------------------------------------
    function Tab:CreateDropdown(config)
        config = config or {}
        local Text = config.Name or "Dropdown"
        local Options = config.Options or {}
        local Default = config.Default or Options[1]
        local Flag = config.Flag or Text
        local Callback = config.Callback or function() end

        local Holder = Create("Frame", {
            Size = UDim2.new(1, 0, 0, 36),
            BackgroundColor3 = Window.Theme.ElementBG,
            ClipsDescendants = true,
            Parent = TabPage,
        }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
        })

        local Head = Create("TextButton", {
            Size = UDim2.new(1, 0, 0, 36),
            BackgroundTransparency = 1,
            Text = "",
            Parent = Holder,
        })

        Create("TextLabel", {
            Text = Text,
            Font = Enum.Font.Gotham,
            TextSize = 14,
            TextColor3 = Window.Theme.Text,
            BackgroundTransparency = 1,
            Size = UDim2.new(0.5, 0, 0, 36),
            Position = UDim2.fromOffset(12, 0),
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = Head,
        })

        local Selected = Create("TextLabel", {
            Text = tostring(Default or ""),
            Font = Enum.Font.Gotham,
            TextSize = 13,
            TextColor3 = Window.Theme.Accent,
            BackgroundTransparency = 1,
            Size = UDim2.new(0.5, -30, 0, 36),
            Position = UDim2.new(0.5, 0, 0, 0),
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent = Head,
        })

        local OptionList = Create("Frame", {
            Size = UDim2.new(1, -12, 0, #Options * 28),
            Position = UDim2.fromOffset(6, 38),
            BackgroundTransparency = 1,
            Parent = Holder,
        }, {
            Create("UIListLayout", { Padding = UDim.new(0, 2) }),
        })

        local open = false
        local function toggleOpen()
            open = not open
            if open then
                Tween(Holder, { Size = UDim2.new(1, 0, 0, 40 + #Options * 28) }, 0.2)
            else
                Tween(Holder, { Size = UDim2.new(1, 0, 0, 36) }, 0.2)
            end
        end
        Head.MouseButton1Click:Connect(toggleOpen)

        for _, opt in ipairs(Options) do
            local OptBtn = Create("TextButton", {
                Size = UDim2.new(1, 0, 0, 26),
                BackgroundColor3 = Window.Theme.Background,
                Text = tostring(opt),
                Font = Enum.Font.Gotham,
                TextSize = 13,
                TextColor3 = Window.Theme.SubText,
                AutoButtonColor = false,
                Parent = OptionList,
            }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 4) }),
            })
            OptBtn.MouseButton1Click:Connect(function()
                Selected.Text = tostring(opt)
                MyHub.Flags[Flag] = opt
                pcall(Callback, opt)
                toggleOpen()
            end)
        end

        MyHub.Flags[Flag] = Default

        table.insert(Window._ThemeRefreshers, function(Theme)
            Holder.BackgroundColor3 = Theme.ElementBG
            Selected.TextColor3 = Theme.Accent
        end)

        return Holder
    end

    return Tab
end

