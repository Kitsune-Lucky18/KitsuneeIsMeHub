----------------------------------------------------------------
-- SetTheme: ganti tema realtime
----------------------------------------------------------------
function KitsuneeIsMe:SetTheme(themeName)
    local Theme = Themes[themeName]
    if not Theme then return end
    self.Theme = Theme
    self.ThemeName = themeName

    Tween(self.Main, { BackgroundColor3 = Theme.Background }, 0.2)
    Tween(self._TopBar, { BackgroundColor3 = Theme.Secondary }, 0.2)
    if self._TabListBG then Tween(self._TabListBG, { BackgroundColor3 = Theme.Secondary }, 0.2) end
    if self._Divider then Tween(self._Divider, { BackgroundColor3 = Theme.Stroke }, 0.2) end

    -- refresh semua elemen yang terdaftar via tag ElementRefs
    for _, refresh in ipairs(self._ThemeRefreshers or {}) do
        pcall(refresh, Theme)
    end
end
KitsuneeIsMe.__newindex = function(t, k, v) rawset(t, k, v) end

