----------------------------------------------------------------
-- SetAccent: override warna accent (semua tema, atau satu tema tertentu)
----------------------------------------------------------------
function KitsuneeIsMe:SetAccent(color, themeName)
    if typeof(color) == "string" then
        local ok, c = pcall(function() return Color3.fromHex(color) end)
        if ok then color = c end
    end
    if themeName and Themes[themeName] then
        Themes[themeName].Accent = color
    else
        for _, t in pairs(Themes) do
            t.Accent = color
        end
    end
    for _, w in ipairs(self._Windows) do
        pcall(function() w:SetTheme(w.ThemeName) end)
    end
end

----------------------------------------------------------------
-- Destroy: tutup semua GUI KitsuneeIsMe (hub, notify, key system, dll)
----------------------------------------------------------------
function KitsuneeIsMe:Destroy()
    for _, w in ipairs(self._Windows) do
        pcall(function() w.ScreenGui:Destroy() end)
    end
    self._Windows = {}
    for _, guiName in ipairs({
        "KitsuneeIsMe_NotifyContainer", "KitsuneeIsMe_KeySystem",
        "KitsuneeIsMe_Watermark", "KitsuneeIsMe_Dialog",
        "KitsuneeIsMe_Prompt", "KitsuneeIsMe_Loading",
    }) do
        local g = CoreGui:FindFirstChild(guiName)
        if g then g:Destroy() end
    end
end

----------------------------------------------------------------
-- CONFIG SYSTEM: Save/Load/Delete — simpan seluruh KitsuneeIsMe.Flags
----------------------------------------------------------------
local function serializeFlags()
    local out = {}
    for k, v in pairs(KitsuneeIsMe.Flags) do
        local t = typeof(v)
        if t == "Color3" then
            out[k] = { __type = "Color3", R = v.R, G = v.G, B = v.B }
        elseif t == "EnumItem" then
            out[k] = { __type = "Enum", enum = tostring(v.EnumType), name = v.Name }
        else
            out[k] = v
        end
    end
    return out
end

local function deserializeValue(v)
    if typeof(v) == "table" and v.__type == "Color3" then
        return Color3.new(v.R, v.G, v.B)
    elseif typeof(v) == "table" and v.__type == "Enum" then
        local ok, item = pcall(function() return Enum[v.enum][v.name] end)
        if ok then return item end
        return nil
    end
    return v
end

-- KitsuneeIsMe:SaveConfig("namaconfig")
function KitsuneeIsMe:SaveConfig(name)
    name = name or "KitsuneeIsMe_Config"
    local ok, err = pcall(function()
        local data = serializeFlags()
        local json = HttpService:JSONEncode(data)
        writefile(name .. ".json", json)
    end)
    if not ok then
        warn("[KitsuneeIsMe] Gagal menyimpan config (executor mungkin nggak support writefile): " .. tostring(err))
    end
    return ok
end

-- KitsuneeIsMe:LoadConfig("namaconfig") — otomatis update semua elemen UI yang terkait Flag-nya
function KitsuneeIsMe:LoadConfig(name)
    name = name or "KitsuneeIsMe_Config"
    local ok, result = pcall(function()
        if not (isfile and isfile(name .. ".json")) then return nil end
        local raw = readfile(name .. ".json")
        return HttpService:JSONDecode(raw)
    end)
    if not ok or not result then return false end
    for flag, rawValue in pairs(result) do
        local value = deserializeValue(rawValue)
        KitsuneeIsMe.Flags[flag] = value
        local setter = KitsuneeIsMe._FlagSetters[flag]
        if setter then pcall(setter, value) end
    end
    return true
end

-- KitsuneeIsMe:DeleteConfig("namaconfig")
function KitsuneeIsMe:DeleteConfig(name)
    name = name or "KitsuneeIsMe_Config"
    local ok = pcall(function()
        if delfile and isfile and isfile(name .. ".json") then
            delfile(name .. ".json")
        end
    end)
    return ok
end

return KitsuneeIsMe
