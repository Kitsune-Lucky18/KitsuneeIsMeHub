-- Loading: overlay spinner + teks, return handle {SetText, Close}
----------------------------------------------------------------
function KitsuneeIsMe:Loading(config)
    config = config or {}
    local Title = config.Title or config.Text or "Loading..."
    local Theme = Themes[config.Theme or "Kitsune"] or Themes.Kitsune

    local existing = CoreGui:FindFirstChild("KitsuneeIsMe_Loading")
    if existing then existing:Destroy() end

    local ScreenGui = Create("ScreenGui", {
        Name = "KitsuneeIsMe_Loading", ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling, Parent = CoreGui,
    })
    Create("Frame", {
        Size = UDim2.fromScale(1, 1), BackgroundColor3 = Color3.new(0, 0, 0),
        BackgroundTransparency = 0.5, BorderSizePixel = 0, Parent = ScreenGui,
    })

    local Panel = Create("Frame", {
        Size = UDim2.fromOffset(220, 90), Position = UDim2.new(0.5, -110, 0.5, -45),
        BackgroundColor3 = Theme.Background, BorderSizePixel = 0, Parent = ScreenGui,
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 12) }),
        Create("UIStroke", { Color = Theme.Stroke, Thickness = 1 }),
    })

    local Spinner = Create("Frame", {
        Size = UDim2.fromOffset(28, 28), Position = UDim2.new(0.5, -14, 0, 16),
        BackgroundTransparency = 1, Parent = Panel,
    })
    local Dot = Create("Frame", {
        Size = UDim2.fromOffset(6, 6), Position = UDim2.new(0.5, -3, 0, 0),
        BackgroundColor3 = Theme.Accent, Parent = Spinner,
    }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })

    task.spawn(function()
        local angle = 0
        while Dot and Dot.Parent do
            angle = (angle + 6) % 360
            local rad = math.rad(angle)
            Dot.Position = UDim2.new(0.5, -3 + 11 * math.sin(rad), 0.5, -3 - 11 * math.cos(rad))
            task.wait(0.02)
        end
    end)

    local TitleLbl = Create("TextLabel", {
        Text = Title, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = Theme.SubText,
        BackgroundTransparency = 1, Size = UDim2.new(1, -20, 0, 20), Position = UDim2.fromOffset(10, 54),
        TextXAlignment = Enum.TextXAlignment.Center, Parent = Panel,
    })

    return {
        SetText = function(_, text) TitleLbl.Text = text end,
        Close = function() if ScreenGui then ScreenGui:Destroy() end end,
    }
end

