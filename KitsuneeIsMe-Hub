-- ─────────────────────────────────────────────
--  TWEEN HELPERS
-- ─────────────────────────────────────────────
local function tw(obj, info, props)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

local TI = {
    fast   = TweenInfo.new(0.16, Enum.EasingStyle.Quad,  Enum.EasingDirection.Out),
    med    = TweenInfo.new(0.26, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
    slow   = TweenInfo.new(0.42, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
    spring = TweenInfo.new(0.48, Enum.EasingStyle.Back,  Enum.EasingDirection.Out),
    bounce = TweenInfo.new(0.55, Enum.EasingStyle.Bounce,Enum.EasingDirection.Out),
    linear = TweenInfo.new(1,    Enum.EasingStyle.Linear),
}

-- ─────────────────────────────────────────────
--  INSTANCE FACTORY
-- ─────────────────────────────────────────────
local function mk(cls, props, parent)
    local i = Instance.new(cls)
    if props then for k,v in pairs(props) do i[k]=v end end
    if parent then i.Parent = parent end
    return i
end

local function corner(p, r)
    local c = mk("UICorner", { CornerRadius = UDim.new(0, r or 8) }, p)
    return c
end

local function stroke(p, col, th)
    return mk("UIStroke", {
        Color = col or T.bord, Thickness = th or 1,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    }, p)
end

local function pad(p, t, r, b, l)
    return mk("UIPadding", {
        PaddingTop    = UDim.new(0, t or 0),
        PaddingRight  = UDim.new(0, r or 0),
        PaddingBottom = UDim.new(0, b or 0),
        PaddingLeft   = UDim.new(0, l or 0),
    }, p)
end

local function vlist(p, gap, ha)
    return mk("UIListLayout", {
        FillDirection       = Enum.FillDirection.Vertical,
        HorizontalAlignment = ha or Enum.HorizontalAlignment.Center,
        Padding             = UDim.new(0, gap or 6),
        SortOrder           = Enum.SortOrder.LayoutOrder,
    }, p)
end

local function hlist(p, gap, va)
    return mk("UIListLayout", {
        FillDirection     = Enum.FillDirection.Horizontal,
        VerticalAlignment = va or Enum.VerticalAlignment.Center,
        Padding           = UDim.new(0, gap or 0),
        SortOrder         = Enum.SortOrder.LayoutOrder,
    }, p)
end

local function lbl(props, parent)
    local l = mk("TextLabel", {
        BackgroundTransparency = 1,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Font                   = Enum.Font.Gotham,
        TextSize               = 13,
        TextColor3             = T.t0,
    }, parent)
    if props then for k,v in pairs(props) do l[k]=v end end
    return l
end

-- pulse loop helper
local function pulse(dot, c1, c2, spd)
    spd = spd or 0.85
    task.spawn(function()
        while dot and dot.Parent do
            tw(dot, TweenInfo.new(spd), { BackgroundColor3 = c2 or T.accD })
            task.wait(spd)
            tw(dot, TweenInfo.new(spd), { BackgroundColor3 = c1 or T.green })
            task.wait(spd)
        end
    end)
end

-- hover util
local function hoverBtn(btn, norm, hov)
    btn.MouseEnter:Connect(function() tw(btn, TI.fast, { BackgroundColor3 = hov }) end)
    btn.MouseLeave:Connect(function() tw(btn, TI.fast, { BackgroundColor3 = norm }) end)
end

