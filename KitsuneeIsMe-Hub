-- Contoh:
--   KitsuneeIsMe:Notify({ Title = "Berhasil", Content = "Fly diaktifkan", Duration = 4, Theme = "Kitsune" })
function KitsuneeIsMe:Notify(config)
    config = config or {}
    local Title    = config.Title or "Notification"
    local Content  = config.Content or ""
    local Duration = config.Duration or 4
    local Theme    = Themes[config.Theme or "Kitsune"] or Themes.Kitsune

    local container = CoreGui:FindFirstChild("KitsuneeIsMe_NotifyContainer")
    if not container then
        container = Create("ScreenGui", {
            Name = "KitsuneeIsMe_NotifyContainer",
            ResetOnSpawn = false,
            ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
            Parent = CoreGui,
        })
        Create("Frame", {
            Name = "Stack",
            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.new(1, -16, 1, -16),
            Size = UDim2.fromOffset(280, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            Parent = container,
        }, {
            Create("UIListLayout", {
                Padding = UDim.new(0, 8),
                VerticalAlignment = Enum.VerticalAlignment.Bottom,
                HorizontalAlignment = Enum.HorizontalAlignment.Right,
                SortOrder = Enum.SortOrder.LayoutOrder,
            }),
        })
    end
    local stack = container.Stack

    local Toast = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = Theme.Background,
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Parent = stack,
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 8) }),
        Create("UIStroke", { Color = Theme.Stroke, Thickness = 1 }),
        Create("UIPadding", {
            PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12),
            PaddingTop = UDim.new(0, 12), PaddingBottom = UDim.new(0, 10),
        }),
        Create("UIListLayout", { Padding = UDim.new(0, 3) }),
    })

    Create("Frame", {
        Size = UDim2.new(1, 24, 0, 3),
        Position = UDim2.fromOffset(-12, -12),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        Parent = Toast,
    })

    Create("TextLabel", {
        Text = Title,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextColor3 = Theme.Text,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 18),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Toast,
    })

    Create("TextLabel", {
        Text = Content,
        Font = Enum.Font.Gotham,
        TextSize = 12,
        TextColor3 = Theme.SubText,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Toast,
    })

    task.delay(Duration, function()
        if Toast and Toast.Parent then
            Tween(Toast, { BackgroundTransparency = 1 }, 0.25)
            task.wait(0.25)
            if Toast then Toast:Destroy() end
        end
    end)
end

return KitsuneeIsMe
