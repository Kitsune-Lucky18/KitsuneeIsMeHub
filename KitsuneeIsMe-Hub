        dot.MouseButton1Click:Connect(function()
            Window:SetTheme(key)
        end)
    end
    makeThemeDot(Themes.Black.Background, "Black")
    makeThemeDot(Themes.White.Background, "White")
    makeThemeDot(Themes.Kitsune.Accent, "Kitsune")

