    function Window:Maximize()
        if not self._Minimized then return end
        self._Minimized = false
        MinimizeBtn.Text = "_"
        Tween(Main, { Size = self._OriginalSize }, 0.2)
        task.wait(0.2)
        TabListBG.Visible = true
        ContentArea.Visible = true
    end

