local function Create(class, props, children)
    local obj = Instance.new(class)
    for k, v in pairs(props or {}) do
        obj[k] = v
    end
    for _, child in ipairs(children or {}) do
        child.Parent = obj
    end
    return obj
end

local function Tween(obj, props, time, style, dir)
    local t = TweenService:Create(
        obj,
        TweenInfo.new(time or 0.25, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props
    )
    t:Play()
    return t
end

local function MakeDraggable(dragHandle, targetFrame)
    local dragging, dragStart, startPos
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = targetFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    dragHandle.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            targetFrame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

----------------------------------------------------------------
-- ICON SYSTEM (mirip Rayfield: nama -> asset id, atau ID langsung)
----------------------------------------------------------------
-- Pakai salah satu:
--   icon = 1234567890                          -> rbxassetid:// otomatis
--   icon = "rbxassetid://1234567890"            -> dipakai apa adanya
--   icon = "home"                                -> dicari di KitsuneeIsMe.Icons["home"]
--
-- Isi KitsuneeIsMe.Icons dengan salah satu cara ini:
--   KitsuneeIsMe:SetIcon("home", 1234567890)
--   KitsuneeIsMe:LoadIconPack("https://raw.githubusercontent.com/.../icons.json")
--       -- format json: { "home": 1234567890, "settings": 987654321, ... }
local function resolveIcon(icon)
    if not icon then return nil end
    if typeof(icon) == "number" then
        return "rbxassetid://" .. icon
    end
    if typeof(icon) == "string" then
        if icon:match("^rbxassetid://") or icon:match("^rbxasset://") or icon:match("^http") then
            return icon
        end
        local mapped = KitsuneeIsMe.Icons[icon]
        if mapped then
            return typeof(mapped) == "number" and ("rbxassetid://" .. mapped) or mapped
        end
    end
    return nil
end

function KitsuneeIsMe:SetIcon(name, id)
    KitsuneeIsMe.Icons[name] = id
end

function KitsuneeIsMe:LoadIconPack(url)
    local ok, result = pcall(function()
        local raw = game:HttpGet(url)
        return HttpService:JSONDecode(raw)
    end)
    if ok and typeof(result) == "table" then
        for name, id in pairs(result) do
            KitsuneeIsMe.Icons[name] = id
        end
        return true
    end
    warn("[KitsuneeIsMe] Gagal load icon pack dari: " .. tostring(url))
    return false
end

local function makeIcon(parent, icon, size, pos)
    local uri = resolveIcon(icon)
    if not uri then return nil end
    return Create("ImageLabel", {
        Image = uri,
        BackgroundTransparency = 1,
        Size = size or UDim2.fromOffset(16, 16),
        Position = pos or UDim2.fromOffset(0, 0),
        Parent = parent,
    })
end

