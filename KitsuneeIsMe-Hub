        self._NameLabel = text
        TitleLabel.Text = text
    end

    -- ==== SelectTab: pilih tab lewat objek Tab, nama, atau index ====
    function Window:SelectTab(identifier)
        for i, t in ipairs(self.Tabs) do
            local match = (t == identifier) or (t.Name == identifier) or (i == identifier)
            if match then
                if t._Select then
                    t._Select()
                else
                    for _, other in ipairs(self.Tabs) do
                        other.Page.Visible = false
                    end
                    t.Page.Visible = true
                    self.CurrentTab = t
                end
                return t
            end
        end
        return nil
    end

    table.insert(Window._ThemeRefreshers, function(Theme)
        MinimizeBtn.TextColor3 = Theme.SubText
        PlayerPanel.BackgroundColor3 = Theme.ElementBG
    end)

    table.insert(KitsuneeIsMe._Windows, Window)

    return Window
end

----------------------------------------------------------------
-- SetTheme: ganti tema realtime
----------------------------------------------------------------
function KitsuneeIsMe:SetTheme(themeName)
    local Theme = Themes[themeName]
    if not Theme then return end
    self.Theme = Theme
    self.ThemeName = themeName

    Tween(self.Main, { BackgroundColor3 = Theme.Background }, 0.2)
    Tween(self._TopBar, { BackgroundColor3 = Theme.Secondary }, 0.2)
    if self._TabListBG then Tween(self._TabListBG, { BackgroundColor3 = Theme.Secondary }, 0.2) end
    if self._Divider then Tween(self._Divider, { BackgroundColor3 = Theme.Stroke }, 0.2) end

    -- refresh semua elemen yang terdaftar via tag ElementRefs
    for _, refresh in ipairs(self._ThemeRefreshers or {}) do
        pcall(refresh, Theme)
    end
end
KitsuneeIsMe.__newindex = function(t, k, v) rawset(t, k, v) end

